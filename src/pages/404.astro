---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="404 — Seite nicht gefunden | HomeIQ Blog" description="Die angefragte Seite existiert nicht. Zurück zum HomeIQ Blog.">
  <div class="not-found">
    <span class="addr">0/0/0 · error</span>
    <h1>404 — Gruppe nicht adressierbar.</h1>
    <p>
      Diese Gruppenadresse existiert nicht im Bus. Die Seite, die du suchst,
      wurde verschoben oder hat nie existiert.
    </p>
    <a class="back-link" href={base}>← Zurück zur Übersicht</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    max-width: 640px;
    margin: 4rem auto;
    text-align: center;
  }
  .not-found h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    margin: 1rem 0;
  }
  .not-found p {
    color: var(--muted);
    margin-bottom: 2rem;
  }
</style>